# ─── Rust Game Server ───────────────────────────────────
RUST_SERVER_NAME=Rust Server
RUST_SERVER_IDENTITY=docker
RUST_SERVER_SEED=12345
RUST_SERVER_WORLDSIZE=3500
RUST_SERVER_MAXPLAYERS=100
RUST_SERVER_PORT=28015
RUST_SERVER_QUERYPORT=28017
RUST_RCON_PORT=28016
RUST_RCON_PASSWORD=changeme
RUST_RCON_WEB=1
RUST_APP_PORT=28082

# Server update - set to 0 to skip SteamCMD update on restart
RUST_UPDATE_ON_START=1

# uMod (Oxide) - set to 0 to disable
UMOD_ENABLED=1

# ─── Web Admin Dashboard ───────────────────────────────
WEB_PORT=3000
ADMIN_USER=admin
ADMIN_PASS=changeme
